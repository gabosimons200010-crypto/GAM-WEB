{
  "name": "gamarra-go",
  "version": "0.0.1",
  "private": true,
  "description": "GAMARRA GO — marketplace multi-tienda de prendas de Gamarra (Lima, Perú)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "db:migrate": "pnpm --filter @gamarra/api db:migrate",
    "db:seed": "pnpm --filter @gamarra/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.7.2"
    },
    "neverBuiltDependencies": ["@prisma/engines", "prisma", "@prisma/client"]
  }
}
