{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@gamarra/api", "dev"],
      "port": 4000,
      "autoPort": false
    },
    {
      "name": "gamarra-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@gamarra/web", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "midnight-drop",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "http-server", "drop", "-p", "4173", "-c-1"],
      "port": 4173
    }
  ]
}
