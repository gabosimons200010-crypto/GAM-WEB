# ─── Entorno ───
NODE_ENV=development
PORT=4000

# ─── Base de datos (PostgreSQL + pgvector) ───
DATABASE_URL=postgresql://gamarra:gamarra@localhost:5432/gamarra?schema=public

# ─── Redis (caché + colas BullMQ) ───
REDIS_URL=redis://localhost:6379

# ─── Búsqueda (OpenSearch) ───
OPENSEARCH_NODE=http://localhost:9200

# ─── Almacenamiento de objetos (S3 / Cloudflare R2 / MinIO en dev) ───
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=gamarra-media
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# ─── Autenticación (JWT) ───
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900            # 15 min (segundos)
JWT_REFRESH_TTL=2592000       # 30 días (segundos)

# ─── IA: Google Gemini (proveedor primario; free tier para MVP) ───
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_BULK=gemini-2.5-flash-lite
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_ESCALATION=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── IA: fallback opcional (Claude / OpenAI) ───
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Frontend (URLs públicas) ───
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000
