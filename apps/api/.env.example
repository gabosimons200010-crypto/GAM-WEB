# ===========================================================================
# GAMARRA GO — API · Variables de entorno (ejemplo)
# Copia este archivo a `.env` y ajusta lo que necesites:
#   Windows PowerShell:  copy apps\api\.env.example apps\api\.env
#   macOS / Linux:       cp apps/api/.env.example apps/api/.env
# Los valores por defecto ya calzan con infra/docker-compose.yml (dev local).
# ===========================================================================

# --- App ---
NODE_ENV=development
PORT=4000
# URL del frontend (para CORS y enlaces). Opcional en dev.
PUBLIC_WEB_URL=http://localhost:3000

# --- Base de datos (PostgreSQL 16 + pgvector) ---
# Coincide con el servicio `postgres` de docker-compose (gamarra/gamarra).
DATABASE_URL=postgresql://gamarra:gamarra@localhost:5432/gamarra

# --- Redis (caché + colas BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- OpenSearch (búsqueda; opcional en Fase 1) ---
OPENSEARCH_NODE=http://localhost:9200

# --- Autenticación (JWT) ---
# En producción usa secretos largos y aleatorios. En dev puedes dejar estos.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900       # 15 min (segundos)
JWT_REFRESH_TTL=2592000  # 30 días (segundos)

# --- IA (Google Gemini) ---
# Sin GEMINI_API_KEY la app usa un proveedor "stub" que devuelve datos de prueba,
# así puedes correr todo el flujo sin gastar cuota. Pon tu key para IA real:
# https://aistudio.google.com/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_BULK=gemini-2.5-flash-lite
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_ESCALATION=gemini-2.5-pro

# --- Almacenamiento de objetos (MinIO en dev = S3 local) ---
# Coincide con el servicio `minio` de docker-compose (minioadmin/minioadmin).
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=gamarra-media
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
# Base pública para servir imágenes (consola MinIO o CDN en prod).
STORAGE_PUBLIC_URL=http://localhost:9000/gamarra-media
