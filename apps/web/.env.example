# URL base de la API de GAMARRA GO (incluye el prefijo /api/v1).
# En dev apunta al backend local (puerto 4000). Copia este archivo a `.env.local`:
#   Windows PowerShell:  copy apps\web\.env.example apps\web\.env.local
#   macOS / Linux:       cp apps/web/.env.example apps/web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
